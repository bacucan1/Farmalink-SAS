{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "cd src && npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "build": {
    "env": {
      "VITE_API_URL": "https://farmalink-gateway.onrender.com"
    }
  }
}