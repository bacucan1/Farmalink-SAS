{
  "buildCommand": "cd src && npm run build",
  "outputDirectory": "src/dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "https://farmalink-gateway.onrender.com"
  }
}