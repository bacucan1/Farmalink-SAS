{
  "buildCommand": "cd $PWD && npm install && cd $PWD/src && npm install && npm run build",
  "outputDirectory": "src/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "build": {
    "env": {
      "VITE_API_URL": "https://farmalink-gateway.onrender.com"
    }
  }
}